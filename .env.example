# Promise View Acres — environment variables
# Copy to .env.local for local dev, and set the same in Amplify → Hosting →
# Environment variables for production. None of these are committed.

# ── Contact form (AWS SES) ──────────────────────────────────────────────
# The verified SES "from" address (must be a verified identity in SES).
CONTACT_FROM_EMAIL=no-reply@promiseviewacres.com
# Where contact submissions are delivered (defaults to the gmail if unset).
CONTACT_TO_EMAIL=promiseviewacres@gmail.com
# SES region (falls back to AWS_REGION, then us-east-1).
CONTACT_SES_REGION=us-east-1
# AWS credentials: NOT needed on Amplify if the compute role has ses:SendEmail.
# For local dev, provide an IAM user's keys with ses:SendEmail:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── The Journey (YouTube Data API v3) ───────────────────────────────────
# Free API key from Google Cloud Console. Without it the Journey page renders
# from the committed seed; with it, exact dates + auto-updates on new uploads.
YOUTUBE_API_KEY=
